{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Agent (Linux, GDB)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/linux-debug/apps/swarmkit-agent",
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "preLaunchTask": "build-project-debug",
      "stopAtEntry": false,
      "externalConsole": false
    },
    {
      "name": "Debug Agent (macOS, LLDB)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/mac-debug/apps/swarmkit-agent",
      "cwd": "${workspaceFolder}",
      "MIMode": "lldb",
      "preLaunchTask": "build-project-debug",
      "stopAtEntry": false,
      "externalConsole": false
    }
  ]
}
