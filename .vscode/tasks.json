{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "conan-install-debug",
      "type": "shell",
      "linux": {
        "command": "bash",
        "args": [
          "-lc",
          "conan install . -of build/conan -s build_type=Debug -s compiler.cppstd=23 --build=missing"
        ]
      },
      "osx": {
        "command": "bash",
        "args": [
          "-lc",
          "conan install . -of build/conan -s build_type=Debug -s compiler.cppstd=23 --build=missing"
        ]
      },
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          "conan install . -of build\\conan -s build_type=Debug -s compiler.cppstd=23 --build=missing"
        ]
      },
      "problemMatcher": []
    },
    {
      "label": "conan-install-release",
      "type": "shell",
      "linux": {
        "command": "bash",
        "args": [
          "-lc",
          "conan install . -of build/conan -s build_type=Release -s compiler.cppstd=23 --build=missing"
        ]
      },
      "osx": {
        "command": "bash",
        "args": [
          "-lc",
          "conan install . -of build/conan -s build_type=Release -s compiler.cppstd=23 --build=missing"
        ]
      },
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          "conan install . -of build\\conan -s build_type=Release -s compiler.cppstd=23 --build=missing"
        ]
      },
      "problemMatcher": []
    },
    {
      "label": "configure-debug",
      "type": "shell",
      "linux": {
        "command": "cmake --preset linux-debug"
      },
      "osx": {
        "command": "cmake --preset mac-debug"
      },
      "windows": {
        "command": "cmake --preset win-debug"
      },
      "dependsOn": [
        "conan-install-debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "configure-release",
      "type": "shell",
      "linux": {
        "command": "cmake --preset linux-release"
      },
      "osx": {
        "command": "cmake --preset mac-release"
      },
      "windows": {
        "command": "cmake --preset win-release"
      },
      "dependsOn": [
        "conan-install-release"
      ],
      "problemMatcher": []
    },
    {
      "label": "build-debug",
      "type": "shell",
      "linux": {
        "command": "cmake --build --preset linux-debug"
      },
      "osx": {
        "command": "cmake --build --preset mac-debug"
      },
      "windows": {
        "command": "cmake --build --preset win-debug"
      },
      "dependsOn": [
        "configure-debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "build-release",
      "type": "shell",
      "linux": {
        "command": "cmake --build --preset linux-release"
      },
      "osx": {
        "command": "cmake --build --preset mac-release"
      },
      "windows": {
        "command": "cmake --build --preset win-release"
      },
      "dependsOn": [
        "configure-release"
      ],
      "problemMatcher": []
    },
    {
      "label": "copy-compile-commands-debug",
      "type": "shell",
      "linux": {
        "command": "bash",
        "args": [
          "-lc",
          "cp build/linux-debug/compile_commands.json ./compile_commands.json && touch compile_commands.json"
        ]
      },
      "osx": {
        "command": "bash",
        "args": [
          "-lc",
          "cp build/mac-debug/compile_commands.json ./compile_commands.json && touch compile_commands.json"
        ]
      },
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          "Copy-Item -Force build\\win-debug\\compile_commands.json .\\compile_commands.json; (Get-Item .\\compile_commands.json) | Out-Null"
        ]
      },
      "dependsOn": [
        "build-debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "copy-compile-commands-release",
      "type": "shell",
      "linux": {
        "command": "bash",
        "args": [
          "-lc",
          "cp build/linux-release/compile_commands.json ./compile_commands.json && touch compile_commands.json"
        ]
      },
      "osx": {
        "command": "bash",
        "args": [
          "-lc",
          "cp build/mac-release/compile_commands.json ./compile_commands.json && touch compile_commands.json"
        ]
      },
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          "Copy-Item -Force build\\win-release\\compile_commands.json .\\compile_commands.json; (Get-Item .\\compile_commands.json) | Out-Null"
        ]
      },
      "dependsOn": [
        "build-release"
      ],
      "problemMatcher": []
    },
    {
      "label": "build-project-debug",
      "dependsOn": [
        "build-debug",
        "copy-compile-commands-debug"
      ],
      "group": {
        "kind": "build"
      },
      "problemMatcher": []
    },
    {
      "label": "build-project-release",
      "dependsOn": [
        "build-release",
        "copy-compile-commands-release"
      ],
      "group": {
        "kind": "build"
      },
      "problemMatcher": []
    },
    {
      "label": "run-agent-debug",
      "type": "shell",
      "linux": {
        "command": "${workspaceFolder}/build/linux-debug/apps/swarmkit-agent"
      },
      "osx": {
        "command": "${workspaceFolder}/build/mac-debug/apps/swarmkit-agent"
      },
      "windows": {
        "command": "${workspaceFolder}\\build\\win-debug\\apps\\swarmkit-agent.exe"
      },
      "dependsOn": [
        "build-project-debug"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "run-cli-debug",
      "type": "shell",
      "linux": {
        "command": "bash",
        "args": [
          "-lc",
          "${workspaceFolder}/build/linux-debug/apps/swarmkit-cli 127.0.0.1:50061"
        ]
      },
      "osx": {
        "command": "bash",
        "args": [
          "-lc",
          "${workspaceFolder}/build/mac-debug/apps/swarmkit-cli 127.0.0.1:50061"
        ]
      },
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          "& \"${workspaceFolder}\\build\\win-debug\\apps\\swarmkit-cli.exe\" 127.0.0.1:50061"
        ]
      },
      "dependsOn": [
        "build-project-debug"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "run-tests-release",
      "type": "shell",
      "linux": {
        "command": "bash",
        "args": [
          "-lc",
          "ctest --preset linux-release --output-on-failure"
        ]
      },
      "osx": {
        "command": "bash",
        "args": [
          "-lc",
          "ctest --preset mac-release --output-on-failure"
        ]
      },
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          "ctest --preset win-release --output-on-failure"
        ]
      },
      "dependsOn": [
        "build-project-release"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "package-sdk-release",
      "type": "shell",
      "linux": {
        "command": "bash",
        "args": [
          "-lc",
          "chmod +x scripts/package_release.sh && ./scripts/package_release.sh linux-release sdk"
        ]
      },
      "osx": {
        "command": "bash",
        "args": [
          "-lc",
          "chmod +x scripts/package_release.sh && ./scripts/package_release.sh mac-release sdk"
        ]
      },
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          ".\\scripts\\package_release.ps1 -Preset win-release -What sdk"
        ]
      },
      "dependsOn": [
        "build-project-release"
      ],
      "problemMatcher": []
    },
    {
      "label": "package-tools-release",
      "type": "shell",
      "linux": {
        "command": "bash",
        "args": [
          "-lc",
          "chmod +x scripts/package_release.sh && ./scripts/package_release.sh linux-release tools"
        ]
      },
      "osx": {
        "command": "bash",
        "args": [
          "-lc",
          "chmod +x scripts/package_release.sh && ./scripts/package_release.sh mac-release tools"
        ]
      },
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          ".\\scripts\\package_release.ps1 -Preset win-release -What tools"
        ]
      },
      "dependsOn": [
        "build-project-release"
      ],
      "problemMatcher": []
    },
    {
      "label": "kb: run (F7)",
      "type": "shell",
      "dependsOn": [
        "run-agent-debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "kb: release + packages (F8)",
      "type": "shell",
      "dependsOn": [
        "build-project-release",
        "run-tests-release",
        "package-sdk-release",
        "package-tools-release"
      ],
      "problemMatcher": []
    }
  ]
}