{
    "version": "2.0.0",
    "tasks": [
        // ----------------------------------------------------------------
        // Conan install (generates toolchain + cmake find-modules)
        // ----------------------------------------------------------------
        {
            "label": "conan-install-debug",
            "type": "shell",
            "linux":   { "command": "bash", "args": ["-lc", "conan install . -of build/conan -s build_type=Debug   -s compiler.cppstd=23 --build=missing"] },
            "osx":     { "command": "bash", "args": ["-lc", "conan install . -of build/conan -s build_type=Debug   -s compiler.cppstd=23 --build=missing"] },
            "problemMatcher": []
        },
        {
            "label": "conan-install-release",
            "type": "shell",
            "linux":   { "command": "bash", "args": ["-lc", "conan install . -of build/conan -s build_type=Release -s compiler.cppstd=23 --build=missing"] },
            "osx":     { "command": "bash", "args": ["-lc", "conan install . -of build/conan -s build_type=Release -s compiler.cppstd=23 --build=missing"] },
            "problemMatcher": []
        },
        // ----------------------------------------------------------------
        // CMake configure
        // ----------------------------------------------------------------
        {
            "label": "configure-debug",
            "type": "shell",
            "linux":   { "command": "cmake --preset linux-debug" },
            "osx":     { "command": "cmake --preset mac-debug"   },
            "dependsOn": ["conan-install-debug"],
            "problemMatcher": []
        },
        {
            "label": "configure-release",
            "type": "shell",
            "linux":   { "command": "cmake --preset linux-release" },
            "osx":     { "command": "cmake --preset mac-release"   },
            "dependsOn": ["conan-install-release"],
            "problemMatcher": []
        },
        // ----------------------------------------------------------------
        // CMake build
        // ----------------------------------------------------------------
        {
            "label": "build-debug",
            "type": "shell",
            "linux":   { "command": "cmake --build --preset linux-debug" },
            "osx":     { "command": "cmake --build --preset mac-debug"   },
            "dependsOn": ["configure-debug"],
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "build-release",
            "type": "shell",
            "linux":   { "command": "cmake --build --preset linux-release" },
            "osx":     { "command": "cmake --build --preset mac-release"   },
            "dependsOn": ["configure-release"],
            "problemMatcher": ["$gcc"]
        },
        // ----------------------------------------------------------------
        // Copy compile_commands.json to project root (for clangd)
        // ----------------------------------------------------------------
        {
            "label": "copy-compile-commands-debug",
            "type": "shell",
            "linux":   { "command": "bash", "args": ["-lc", "cp build/linux-debug/compile_commands.json  ./compile_commands.json && touch compile_commands.json"] },
            "osx":     { "command": "bash", "args": ["-lc", "cp build/mac-debug/compile_commands.json    ./compile_commands.json && touch compile_commands.json"] },
            "dependsOn": ["build-debug"],
            "problemMatcher": []
        },
        {
            "label": "copy-compile-commands-release",
            "type": "shell",
            "linux":   { "command": "bash", "args": ["-lc", "cp build/linux-release/compile_commands.json ./compile_commands.json && touch compile_commands.json"] },
            "osx":     { "command": "bash", "args": ["-lc", "cp build/mac-release/compile_commands.json   ./compile_commands.json && touch compile_commands.json"] },
            "dependsOn": ["build-release"],
            "problemMatcher": []
        },
        // ----------------------------------------------------------------
        // Compound build tasks (used as F5/F6 targets and as dependencies)
        // ----------------------------------------------------------------
        {
            "label": "build-project-debug",
            "dependsOn": ["build-debug", "copy-compile-commands-debug"],
            "dependsOrder": "parallel",
            "group": { "kind": "build" },
            "problemMatcher": []
        },
        {
            "label": "build-project-release",
            "dependsOn": ["build-release", "copy-compile-commands-release"],
            "dependsOrder": "parallel",
            "group": { "kind": "build" },
            "problemMatcher": []
        },
        // ----------------------------------------------------------------
        // Tests
        // ----------------------------------------------------------------
        {
            "label": "run-tests-release",
            "type": "shell",
            "linux":   { "command": "bash", "args": ["-lc", "ctest --preset linux-release --output-on-failure"] },
            "osx":     { "command": "bash", "args": ["-lc", "ctest --preset mac-release   --output-on-failure"] },
            "dependsOn": ["build-project-release"],
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        // ----------------------------------------------------------------
        // Packaging — runs after tests, produces sdk + tools tarballs.
        // ----------------------------------------------------------------
        {
            "label": "package-release",
            "type": "shell",
            "linux":   { "command": "bash", "args": ["-lc", "chmod +x scripts/ci_package_linux_x86_64.sh && ./scripts/ci_package_linux_x86_64.sh"] },
            "osx":     { "command": "bash", "args": ["-lc", "chmod +x scripts/ci_package_mac_arm64.sh  && ./scripts/ci_package_mac_arm64.sh"] },
            "dependsOn": ["run-tests-release"],
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        // ----------------------------------------------------------------
        // Deploy SDK — extract tarball to ~/swarmkit-sdk
        // ----------------------------------------------------------------
        {
            "label": "deploy-sdk",
            "type": "shell",
            "osx":     { "command": "bash", "args": ["-lc", "chmod +x scripts/deploy_sdk_mac.sh && ./scripts/deploy_sdk_mac.sh"] },
            "linux":   { "command": "bash", "args": ["-lc", "echo 'deploy_sdk_mac.sh is macOS only; skipping.'"] },
            "dependsOn": ["package-release"],
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        // ----------------------------------------------------------------
        // Run targets
        // ----------------------------------------------------------------
        {
            "label": "run-agent-debug",
            "type": "shell",
            "linux":   { "command": "${workspaceFolder}/build/linux-debug/apps/swarmkit-agent" },
            "osx":     { "command": "${workspaceFolder}/build/mac-debug/apps/swarmkit-agent"   },
            "dependsOn": ["build-project-debug"],
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "run-agent-release",
            "type": "shell",
            "linux":   { "command": "${workspaceFolder}/build/linux-release/apps/swarmkit-agent" },
            "osx":     { "command": "${workspaceFolder}/build/mac-release/apps/swarmkit-agent"   },
            "dependsOn": ["build-project-release"],
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "run-cli-debug",
            "type": "shell",
            "linux":   { "command": "bash", "args": ["-lc", "${workspaceFolder}/build/linux-debug/apps/swarmkit-cli 127.0.0.1:50061"] },
            "osx":     { "command": "bash", "args": ["-lc", "${workspaceFolder}/build/mac-debug/apps/swarmkit-cli   127.0.0.1:50061"] },
            "dependsOn": ["build-project-debug"],
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        // ----------------------------------------------------------------
        // Keybinding aliases — labels must match keybindings.json exactly
        //   F6       → kb: build debug
        //   Shift+F6 → kb: build release
        //   F7       → kb: run debug     (starts agent)
        //   Shift+F7 → kb: run release   (starts agent, release build)
        //   F8       → kb: deploy installer (build + test + package)
        // ----------------------------------------------------------------
        {
            "label": "kb: build debug",
            "dependsOn": ["build-project-debug"],
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": []
        },
        {
            "label": "kb: build release",
            "dependsOn": ["build-project-release"],
            "group": { "kind": "build" },
            "problemMatcher": []
        },
        {
            "label": "kb: run debug",
            "dependsOn": ["run-agent-debug"],
            "problemMatcher": []
        },
        {
            "label": "kb: run release",
            "dependsOn": ["run-agent-release"],
            "problemMatcher": []
        },
        {
            "label": "kb: deploy installer",
            "dependsOn": ["deploy-sdk"],
            "problemMatcher": []
        }
    ]
}
